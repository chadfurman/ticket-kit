{
  "$comment": "Consuming-repo overrides for change-factory agent-health lint. Layered on top of the plugin's resources/lint.config.json defaults. ticket-kit specifics: the board IS a UX surface, mmdc is present, tracking is ticket-kit-not-Jira, and the repo merges straight to main.",
  "conditionalReviewers": {
    "ux-reviewer": {
      "enabled": true,
      "$comment": "ticket-kit renders an HTML/CSS kanban board (serve.ts/generate.ts/detail.ts) — a real user-facing surface, so ux-reviewer is enabled."
    }
  },
  "diagrams": {
    "visualValidation": true,
    "$comment": "mmdc (mermaid-cli) is installed in this environment — the rendered screen-fit/density critique is available."
  },
  "ticketing": {
    "enabled": false,
    "jira-project-key": null,
    "$comment": "This repo dogfoods ticket-kit itself for work-item tracking (tickets/*.md), not Jira. The Jira gate stays disabled."
  },
  "delivery": {
    "defaultEndState": "push",
    "$comment": "Team convention (chadfurman, 2026-06-09): always merge to main on this repo — no PR-gating default."
  },
  "workspaceRepos": {
    "paths": []
  }
}
